// GOOD CODE


struct FnState
{
    bool pressed = false;
    bool holdTriggered = false;
    bool stepUsed = false; // Step ou Encodeur utilisé pendant le Fn
};

struct StepState
{
    bool pressed = false;
    ControlId stepId; // Step actuellement pressé
};

FnState m_fn;
ControlId m_currentFn;

StepState m_step;

// Helpers
constexpr bool isFn(ControlId c)
{
    return c >= ControlId::Fn0 && c <= ControlId::Fn7;
}

constexpr bool isStep(ControlId c)
{
    return c >= ControlId::Step0 && c <= ControlId::Step3;
}

constexpr bool isEncoder(ControlId c)
{
    return c == ControlId::Encoder0 || c == ControlId::Encoder1;
}

uint8_t fnIndex(ControlId c)
{
    return static_cast<uint8_t>(c) - static_cast<uint8_t>(ControlId::Fn0);
}

// Main event handler
void handleEvent(InputEventType type, ControlId control, int delta = 0)
{
    switch(type)
    {
        case InputEventType::ButtonPressed:
        {
            if (isFn(control))
            {
                m_fn.pressed = true;
                m_fn.holdTriggered = false;
                m_fn.stepUsed = false;
                m_currentFn = control;
            }
            else if (isStep(control))
            {
                m_step.pressed = true;
                m_step.stepId = control;

                if (m_fn.pressed)
                    m_fn.stepUsed = true; // Step modifie le Fn
            }
            break;
        }

        case InputEventType::ButtonHold:
        {
            if (isFn(control) && control == m_currentFn)
                m_fn.holdTriggered = true;
            break;
        }

        case InputEventType::ButtonRelease:
        {
            if (isFn(control) && control == m_currentFn)
            {
                // Fn hold action
                if (m_fn.holdTriggered && !m_fn.stepUsed)
                    autreAction(control);

                m_fn.pressed = false;
                m_fn.holdTriggered = false;
                m_fn.stepUsed = false;
            }
            else if (isStep(control) && m_step.pressed && control == m_step.stepId)
            {
                // Step action déclenchée au release
                if (m_fn.pressed)
                    changePattern(control, m_currentFn); // Step + Fn
                else
                    changePattern(control);             // Step seul

                m_step.pressed = false;
            }
            break;
        }

        case InputEventType::EncoderTurned:
        {
            if (!isEncoder(control)) break;

            if (m_fn.pressed)
            {
                m_fn.stepUsed = true;        // consomme le Hold du Fn
                actionA(control, delta);     // Encodeur + Fn
            }
            else
            {
                actionB(control, delta);     // Encodeur seul
            }
            break;
        }

        default:
            break;
    }
}
