#pragma once

#include <Arduino.h>

enum class InputEventType
{
    ButtonPressed,
    ButtonReleased,
    ButtonHold,

    EncoderTurned,
    EncoderPressed,
    EncoderReleased
};

struct InputEvent
{
    InputEventType type;

    uint8_t id;

    int16_t value;
};

#pragma once

#include "InputEvent.h"

class IMode
{
public:

    virtual void onEnter() {}
    virtual void onExit() {}

    virtual void handleEvent(const InputEvent& event) = 0;
};

#pragma once

#include "Input.h"
#include "IMode.h"

class InputManager
{
public:

    InputManager(Input& _input):
        input(_input)
    {
    }

    void setMode(IMode* mode)
    {
        if(currentMode) {
            currentMode->onExit();
        }

        currentMode = mode;

        if(currentMode) {
            currentMode->onEnter();
        }
    }

    void update()
    {
        InputEvent event;

        while(input.popEvent(event)) {

            if(currentMode) {

                currentMode->handleEvent(event);
            }
        }
    }

private:

    Input& input;

    IMode* currentMode = nullptr;
};

#pragma once

#include "IMode.h"

class MainMode : public IMode
{
public:

    void handleEvent(const InputEvent& event) override
    {
        switch(event.type) {

            case InputEventType::ButtonPressed:

                Serial.print("Button pressed: ");
                Serial.println(event.id);

                break;

            case InputEventType::EncoderTurned:

                Serial.print("Encoder value: ");
                Serial.println(event.value);

                break;

            default:
                break;
        }
    }
};
