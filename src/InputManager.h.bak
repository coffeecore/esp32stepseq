#pragma once

#include "AiEsp32RotaryEncoder.h"
#include "Arduino.h"
#include "Constants.h"
#include "SequencerTimer.h"
#include <Bounce2.h>
#include <Keypad.h>

enum InputEventType
{
    ButtonPressed,
    ButtonReleased,
    ButtonHold,

    EncoderTurned,
    EncoderPressed,
    EncoderReleased
};

typedef struct
{
    InputEventType type;

    uint8_t id;

    int16_t value;
} InputEvent;

class InputManager
{
    public:
        volatile InputEvent ringBuffer[32];
        volatile uint8_t writeIndex;
        volatile uint8_t readIndex;

        InputManager(SequencerTimer& _sequencerTimer):
            sequencerTimer(_sequencerTimer)
        {
        }
        uint8_t getButtonIndex(char key) const
        {
            return key - 'A';
        }

        uint8_t getRow(char key) const
        {
            return getButtonIndex(key) / Constants::COLS;
        }

        uint8_t getColumn(char key) const
        {
            return getButtonIndex(key) % Constants::COLS;
        }

        int8_t getStep(char key) const
        {
            uint8_t buttonIndex = getButtonIndex(key);

            if (buttonIndex < 4) {
                return -1;
            }

            return buttonIndex - 4;
        }



        void begin()
        {
            instance = this;

            // for (uint8_t i = 0; i < Constants::NUMBER_OF_ROTARY_ENCODERS; i++) {
            //     rotaryEncoderButtons[i].attach(Constants::ROTARY_ENCODERS_PIN[i][2], INPUT_PULLUP);
            //     rotaryEncoderButtons[i].interval(5);
            //     rotaryEncoderButtons[i].setPressedState(LOW);
            // }

            // for (uint8_t i = 0;i < Constants::NUMBER_OF_ROTARY_ENCODERS; i++) {
            //     rotaryEncoders[i] = AiEsp32RotaryEncoder(Constants::ROTARY_ENCODERS_PIN[i][0], Constants::ROTARY_ENCODERS_PIN[i][1], Constants::ROTARY_ENCODERS_PIN[i][2], -1, 4);

            //     rotaryEncoders[i].begin();
            //     rotaryEncoders[i].setup(readEncoderISR);
            //     rotaryEncoders[i].setAcceleration(200);
            //     rotaryEncoders[i].setBoundaries(0, 255, false);
            //     rotaryEncoders[Constants::ROTARY_ENCODER_A].setEncoderValue(sequencerTimer.getVolume());
            // }


            xTaskCreatePinnedToCore(
                controlTask,
                "InputManagerTask",
                8192,
                this,
                1,
                &xHandle,
                0
            );
        }

        static void controlTask(void* pvParameters)
        {
            InputManager* inputManager = static_cast<InputManager*>(pvParameters);
            for (;;) {
                ulTaskNotifyTake(pdTRUE, portMAX_DELAY);

                while(inputManager->readIndex != inputManager->writeIndex) {

                    InputEvent& e = inputManager->ringBuffer[inputManager->readIndex];

                    // currentMode->handleEvent(e);

                    inputManager->readIndex = (inputManager->readIndex + 1) % 32;
                }

                vTaskDelay(pdMS_TO_TICKS(10));
            }
        }

        void pushEvent(const InputEvent& e)
        {
            ringBuffer[writeIndex] = e;

            writeIndex = (writeIndex + 1) % 32;

            xTaskNotifyGive(xHandle);
        }
    
    private:
        TaskHandle_t xHandle = nullptr;
        SequencerTimer& sequencerTimer;
        static InputManager* instance;
        
};
InputManager* InputManager::instance = nullptr;






